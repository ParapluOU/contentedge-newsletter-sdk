{
  "name": "@codesocietyou/contentedge-newsletter-sdk",
  "version": "0.1.1",
  "description": "Framework-agnostic browser SDK for ContentEdge newsletter public forms.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "contentedge",
    "newsletter",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ParapluOU/contentedge-newsletter-sdk.git"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "^4.1.6"
  }
}
